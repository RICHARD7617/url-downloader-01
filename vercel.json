{
  "buildCommand": "pnpm install && pnpm --filter @workspace/url-downloader run build",
  "outputDirectory": "artifacts/url-downloader/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
